# Meeting Secretary Configuration

# Database
DATABASE_URL=sqlite:///./meeting_secretary.db

# Whisper ASR Settings
WHISPER_MODEL=small  # tiny, base, small, medium, large-v3
WHISPER_DEVICE=cuda  # cuda or cpu
WHISPER_COMPUTE_TYPE=float16  # float16, int8_float16 (GPU) or int8 (CPU)

# Task Extraction
TASK_MODEL=google/flan-t5-large
MAX_TASK_MODEL_TOKENS=1024
USE_OLLAMA=false  # Set true to use Ollama instead of T5
OLLAMA_MODEL=codellama:7b
OLLAMA_URL=http://localhost:11434

# Diarization
DIARIZATION_ENABLED=true

# Audio Preprocessing
AUDIO_TARGET_SR=16000
AUDIO_NORMALIZE=true
AUDIO_REDUCE_NOISE=false  # requires noisereduce library

# Quality
MIN_TRANSCRIPT_CONFIDENCE=0.6